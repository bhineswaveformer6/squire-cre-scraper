# Squire — CRE Intelligence Agent
# Copy to .env and fill in your keys

# ScraperAPI — proxy layer for HTML scraping (anti-bot)
SCRAPERAPI_KEY=your_scraperapi_key_here

# CoStar — authenticated session (optional, skipped if blank)
COSTAR_USERNAME=your_costar_email
COSTAR_PASSWORD=your_costar_password

# Crexi — structured JSON API (optional, falls back to HTML scrape)
CREXI_API_KEY=your_crexi_api_key_here

# Qualification gates
MIN_CAP_RATE=0.05
MIN_DSCR=1.25

# Markets to scan (comma-separated)
TARGET_MARKETS=Miami,New York City,Dallas,Los Angeles,Chicago
